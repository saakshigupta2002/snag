# ── Snag environment variables ────────────────────────────────────────────────
# Copy to .env and fill in. Every value ships blank on purpose:
# the public repo is the machine with empty slots — your deployment fills them.
# NEVER commit a real value to a public repo.

# Postgres connection string (Supabase, Neon, RDS, or the docker-compose db).
# e.g. postgres://snag:snag@localhost:5432/snag
DATABASE_URL=

# Port for the ingestion + API service (default 8787).
PORT=

# Public origin of the ingest service, as seen from the dashboard server
# e.g. http://localhost:8787
INGEST_URL=

# Shared token the dashboard uses to call the ingest management API.
# Generate one: openssl rand -hex 32
SNAG_API_TOKEN=

# Secret used to sign dashboard session cookies.
# Generate one: openssl rand -hex 32
SNAG_SECRET=

# Password for dashboard login (single-user auth in v1).
DASHBOARD_PASSWORD=

# Session retention default, in days (per-project override in settings).
RETENTION_DAYS=

# ── Optional AI layer (off unless a key is present; you pay your own bill) ────
# Provider: "anthropic" or "openai"
AI_PROVIDER=
AI_API_KEY=
# Optional model override (sensible cheap default per provider otherwise)
AI_MODEL=
# Hard ceiling on model calls per day (default 50)
AI_DAILY_CAP=
