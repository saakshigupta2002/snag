{
  "name": "@snag/ingest",
  "version": "0.1.0",
  "description": "Snag ingestion API + background workers: receives event batches, stores sessions, runs the detection engine.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
