    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cors": "^11.3.0",
    "@snag/detectors": "*",
    "@snag/shared": "*",
    "fastify": "^5.10.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
