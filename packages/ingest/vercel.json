{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd ../.. && npm run build -w @snag/shared -w @snag/detectors -w @snag/ingest",
  "framework": null,
  "routes": [{ "src": "/(.*)", "dest": "/api/index.ts" }],
  "functions": {
    "api/index.ts": { "maxDuration": 60 }
  },
  "crons": [{ "path": "/api/admin/tick", "schedule": "0 3 * * *" }]
}
